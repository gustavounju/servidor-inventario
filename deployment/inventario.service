[Unit]
Description=Servidor Inventario GOLD (Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/inventario
EnvironmentFile=-/opt/inventario/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/inventario/.venv/bin/gunicorn --workers 3 --bind 127.0.0.1:5001 --timeout 120 servidor:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
