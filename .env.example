FLASK_SECRET_KEY=cambia_esta_clave_larga_y_privada

DB_PORT=3306
DB_USER=root
DB_PASS=cambia_esta_clave
DB_NAME=inventario_prod

# IP o hostname del MySQL de produccion.
# Puede ser otro servidor distinto al de Inventario.
DB_HOST=127.0.0.1

# En Linux/producción con HTTPS esto se fuerza a True automáticamente.
# Solo necesario cambiarlo a 'true' si usás HTTPS en Windows (desarrollo).
SESSION_COOKIE_SECURE=false

# URL publica del servidor Inventario que usan las PCs cliente.
# No tiene relacion con DB_HOST.
INVENTARIO_PUBLIC_BASE_URL=
INVENTARIO_PUBLIC_HTTP_FALLBACK_URL=

# Usuario bootstrap inicial. Solo se recrea si app_users queda vacia.
BOOTSTRAP_ADMIN_USERNAME=administrador
BOOTSTRAP_ADMIN_PASSWORD=tdg729tdg

# Token opcional para clientes/API internos.
INVENTARIO_API_TOKEN=

# Autenticacion: local | ad | hybrid
AUTH_MODE=local

# Active Directory / LDAP (dejar vacio hasta activarlo)
AD_SERVER=
AD_DOMAIN=
AD_BASE_DN=
AD_USE_SSL=false
AD_CONNECT_TIMEOUT=5
AD_SUPERUSERS=
AD_SYNC_USER=
AD_SYNC_PASSWORD=

# OCR local para PDFs en el Vault
PDF_OCR_LANG=spa+eng
PDF_OCR_DPI=300
PDF_OCR_MIN_CHARS=20
TESSERACT_CMD=
